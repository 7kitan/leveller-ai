# ------------------------------------------------------------------------------
# Backend Environment Configuration
# ------------------------------------------------------------------------------

# --- Database (PostgreSQL + pgvector) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password # MANDATORY IN PROD
POSTGRES_DB=career_advisor
POSTGRES_HOST=advisor_db_prod
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=advisor_redis_prod
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password # MANDATORY IN PROD

# --- Gateway & Services ---
ENVIRONMENT=production
GATEWAY_PORT=8000
AUTH_SVC_URL=http://advisor_auth_prod:8000
CV_SVC_URL=http://advisor_cv_prod:8000
JD_SVC_URL=http://advisor_jd_prod:8000
ANALYSIS_SVC_URL=http://advisor_analysis_prod:8000
RECOMMEND_SVC_URL=http://advisor_recommender_prod:8000

# --- Security ---
SECRET_KEY=your_secret_key_here
# ALLOWED_ORIGINS: Danh sách các Domain của Frontend được phép gọi tới API
# Phân cách bằng dấu phẩy. Ví dụ: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# --- LLM ---
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
YOUTUBE_API_KEY=...
