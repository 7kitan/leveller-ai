# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=career_advisor
POSTGRES_HOST=advisor_db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=advisor_redis
REDIS_PORT=6379

# Caching Configuration (Granular Toggles)
CACHE_ENABLED=true
CACHE_AUTH_ENABLED=true
CACHE_RESULT_ENABLED=true
CACHE_LLM_ENABLED=true
CACHE_TAXONOMY_ENABLED=true
CACHE_CV_RAW_TEXT_ENABLED=true
CACHE_CV_PARSED_JSON_ENABLED=true
CACHE_KEY_PREFIX=advisor:
CACHE_DEFAULT_TTL=3600

# Cache Database Indexes
CACHE_DB_AUTH=0
CACHE_DB_RESULT=2
CACHE_DB_LLM=3
CACHE_DB_TAXONOMY=4

# Cache Expiration (Seconds)
CACHE_TTL_AUTH=86400
CACHE_TTL_RESULT=3600
CACHE_TTL_LLM=604800
CACHE_TTL_TAXONOMY=2592000

# Neo4j
NEO4J_URI=bolt://advisor_neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=cv-files

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-proj-cac-ma-key-cua-ban-o-day

# Gemini API (Optional fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT
JWT_SECRET=super_secret_key_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OCR & ANALYSIS APIS ---
CHANDRA_API_URL=https://api.datalab.to/api/v1/ocr
CHANDRA_API_KEY=your_chandra_api_key_here
BERTSCORE_API_URL=https://api.yourserver.com/bertscore
BERTSCORE_API_KEY=your_bertscore_api_key_here

# CV Parsing Strategy (hybrid, direct, ocr)
# Options: hybrid, direct, ocr
CV_PARSING_STRATEGY=hybrid
CV_PARSING_OCR_THRESHOLD=200
CV_PARSING_MAX_RETRIES=3

# --- SKILL GAP CALCULATION ---
# Order of matching layers to evaluate. Defines how you combine multiple algorithms.
# Options: exact, graph, semantic
GAP_MATCHING_LAYERS=exact,graph
