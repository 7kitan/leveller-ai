# ------------------------------------------------------------------------------
# Backend Environment Configuration
# ------------------------------------------------------------------------------
# IMPORTANT: Copy this file to .env and fill in all REQUIRED values
# Generate secure values using the commands provided in comments

# --- Database (PostgreSQL + pgvector) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password_min_16_chars # REQUIRED IN PROD
POSTGRES_DB=career_advisor
POSTGRES_HOST=advisor_db_prod
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=advisor_redis_prod
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_min_16_chars # REQUIRED IN PROD
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# --- Security (CRITICAL - MUST SET IN PROD) ---
# JWT Secret - Used for token signing
JWT_SECRET=your_jwt_secret_min_32_chars # REQUIRED IN PROD
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Redis Encryption Key - Used for session encryption
REDIS_ENCRYPTION_KEY=your_fernet_key_here # REQUIRED IN PROD
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Environment ---
ENVIRONMENT=production # production | staging | development
DEBUG=false # true | false (Set to true in development to bypass Captcha and see more logs)

# --- Gateway & Services ---
AUTH_SVC_URL=http://advisor_auth_prod:8000
CV_SVC_URL=http://advisor_cv_prod:8000
JD_SVC_URL=http://advisor_jd_prod:8000
ANALYSIS_SVC_URL=http://advisor_analysis_prod:8000
RECOMMEND_SVC_URL=http://advisor_recommender_prod:8000
ADMIN_SVC_URL=http://advisor_admin_prod:8000

# --- CORS & Frontend ---
FRONTEND_URL=https://yourdomain.com # REQUIRED IN PROD

# ALLOWED_ORIGINS: Comma-separated list of allowed frontend origins
# IMPORTANT: Must include FULL origin (protocol + domain + port)
# 
# Production example:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
#
# Development example (backend on server, frontend on localhost):
# ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000,http://localhost:5173
#
# Common frontend dev ports:
# - React (CRA): 3000
# - Next.js: 3000
# - Vite: 5173
# - Vue CLI: 8080
# - Angular: 4200
#
# ❌ WRONG: localhost (missing protocol and port)
# ❌ WRONG: https://localhost (HTTPS on localhost usually doesn't work without cert)
# ✅ CORRECT: http://localhost:3000
#
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://localhost:3000 # REQUIRED IN PROD

# --- Authentication & Tokens ---
# Access Token: Single long-lived token for API requests (7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days (7 * 24 * 60 minutes)

# Note: Tokens are sent via Authorization header (not cookies)

# --- LLM & AI Services ---
# OpenAI
OPENAI_API_KEY=sk-proj-... # REQUIRED if using OpenAI

# Google API Key (for Gemini AI and YouTube API)
GOOGLE_API_KEY=AIza... # REQUIRED if using Gemini or YouTube features
# Get from: https://console.cloud.google.com/apis/credentials

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api... # REQUIRED if using Claude models

# Note: AI model settings (AI_MODEL, GAP_LLM_MODEL, etc.) are configured 
# in Admin Settings UI and stored in database. Default: gpt-4o-mini

# --- Google Services ---
# reCAPTCHA v2 (REQUIRED for registration/login security)
GOOGLE_RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key # REQUIRED IN PROD
# Get from: https://www.google.com/recaptcha/admin

# YouTube API (Optional - uses GOOGLE_API_KEY if not set)
YOUTUBE_API_KEY=your_youtube_api_key # Optional
# Get from: https://console.cloud.google.com/apis/credentials

# --- Worker Configuration ---
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# --- Optional: External Services ---
# Global Proxy List (Recommended for non-Vietnam servers)
# If your server is outside Vietnam, TopCV and other sites may show CAPTCHA challenges
# Use Vietnam-based proxies to bypass geo-restrictions
# Format: IP:PORT:USER:PASS (supports both newline-separated and comma-separated)
# Example (newline): 
#   107.150.110.153:4157:1tkPxigNT4YM:5MH6SNHd6r5g
#   108.160.120.154:4158:user2:pass2
# Example (comma): 107.150.110.153:4157:user1:pass1,108.160.120.154:4158:user2:pass2
# Configure via Admin Settings UI → Automation tab (key: PROXY_LIST)
# This proxy list will be used by all crawlers (TopCV, future crawlers)
# --- AI Inference Hub (Chandra OCR) ---
CHANDRA_API_URL=http://localhost:8080/tasks/ocr
CHANDRA_API_KEY=debug_key_123
