# ------------------------------------------------------------------------------
# Backend Environment Configuration
# ------------------------------------------------------------------------------
# IMPORTANT: Copy this file to .env and fill in all REQUIRED values
# Generate secure values using the commands provided in comments

# --- Database (PostgreSQL + pgvector) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password_min_16_chars # REQUIRED IN PROD
POSTGRES_DB=career_advisor
POSTGRES_HOST=advisor_db_prod
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=advisor_redis_prod
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_min_16_chars # REQUIRED IN PROD
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# --- Security (CRITICAL - MUST SET IN PROD) ---
# JWT Secret - Used for token signing
JWT_SECRET=your_jwt_secret_min_32_chars # REQUIRED IN PROD
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Redis Encryption Key - Used for session encryption
REDIS_ENCRYPTION_KEY=your_fernet_key_here # REQUIRED IN PROD
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Secret Key - General purpose secret
SECRET_KEY=your_secret_key_here
# Generate: python -c "import secrets; print(secrets.token_hex(32))"

# --- Environment ---
ENVIRONMENT=production # production | staging | development

# --- Gateway & Services ---
GATEWAY_PORT=8000
AUTH_SVC_URL=http://advisor_auth_prod:8000
CV_SVC_URL=http://advisor_cv_prod:8000
JD_SVC_URL=http://advisor_jd_prod:8000
ANALYSIS_SVC_URL=http://advisor_analysis_prod:8000
RECOMMEND_SVC_URL=http://advisor_recommender_prod:8000
ADMIN_SVC_URL=http://advisor_admin_prod:8000

# --- CORS & Frontend ---
FRONTEND_URL=https://yourdomain.com # REQUIRED IN PROD
# ALLOWED_ORIGINS: Comma-separated list of allowed frontend domains
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com # REQUIRED IN PROD

# --- Authentication & Tokens ---
ACCESS_TOKEN_EXPIRE_MINUTES=120 # 2 hours
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Quota & Rate Limiting ---
DAILY_ANALYSIS_LIMIT=10 # Max analyses per user per day
DAILY_TOKEN_LIMIT=50000 # Max LLM tokens per user per day

# --- LLM & AI Services ---
# OpenAI
OPENAI_API_KEY=sk-proj-... # REQUIRED if using OpenAI
LLM_MODEL=gpt-4o-mini
AI_MODEL=gpt-4o-mini

# Google Gemini (Optional alternative)
GOOGLE_API_KEY=AIza... # Optional

# AI Inference Hub (Optional self-hosted)
AI_INFERENCE_API_KEY=your_ai_hub_key # Optional
AI_INFERENCE_URL=http://your-ai-hub:8080 # Optional

# --- Google Services ---
# reCAPTCHA v2 (REQUIRED for registration/login security)
GOOGLE_RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key # REQUIRED IN PROD
# Get from: https://www.google.com/recaptcha/admin

# YouTube API (Optional - for course video metadata)
YOUTUBE_API_KEY=your_youtube_api_key # Optional
# Get from: https://console.cloud.google.com/apis/credentials

# --- Email (SMTP) ---
# Required for password reset emails
SMTP_HOST=smtp.gmail.com # REQUIRED IN PROD
SMTP_PORT=587 # REQUIRED IN PROD
SMTP_USER=your-email@gmail.com # REQUIRED IN PROD
SMTP_PASSWORD=your_app_specific_password # REQUIRED IN PROD
SMTP_FROM_EMAIL=noreply@yourdomain.com # REQUIRED IN PROD
SMTP_FROM_NAME=Lumix AI

# --- Feature Flags ---
USE_LLM_GAP_AGENT_V3=true # Use v3 LLM-based gap analysis
JD_USE_VECTOR_SEARCH=true # Use vector search for jobs
USE_VECTOR_SEARCH=true # Global vector search flag

# --- Logging & Monitoring ---
LOG_LEVEL=INFO # DEBUG | INFO | WARNING | ERROR | CRITICAL
SYSTEM_LOG_RETENTION_DAYS=30 # Auto-cleanup logs older than X days

# --- Worker Configuration ---
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# Worker Concurrency (number of parallel tasks per worker)
WORKER_CV_PARSER_CONCURRENCY=2
WORKER_ANALYSIS_CONCURRENCY=2
WORKER_MARKET_STATS_CONCURRENCY=1
WORKER_EMAIL_CONCURRENCY=2

# --- Optional: External Services ---
# TopCV Proxy (Recommended for non-Vietnam servers)
# If your server is outside Vietnam, TopCV may show CAPTCHA challenges
# Use a Vietnam-based proxy to bypass geo-restrictions
# Format: http://user:pass@proxy.com:8080 or socks5://proxy.com:1080
TOPCV_PROXY= # Optional but recommended for Singapore/overseas servers

# Sentry (Error tracking)
SENTRY_DSN= # Optional

# Google Analytics
GA_TRACKING_ID= # Optional

# ------------------------------------------------------------------------------
# DEPLOYMENT CHECKLIST
# ------------------------------------------------------------------------------
# Before deploying to production, ensure you have set:
# ✅ POSTGRES_PASSWORD (strong password, min 16 chars)
# ✅ REDIS_PASSWORD (strong password, min 16 chars)
# ✅ JWT_SECRET (generated with command above, min 32 chars)
# ✅ REDIS_ENCRYPTION_KEY (generated with command above)
# ✅ GOOGLE_RECAPTCHA_SECRET_KEY (from Google reCAPTCHA admin)
# ✅ OPENAI_API_KEY (from OpenAI dashboard)
# ✅ SMTP credentials (for email functionality)
# ✅ FRONTEND_URL (your actual domain)
# ✅ ALLOWED_ORIGINS (your actual domains)
#
# Verify all required variables:
# docker-compose config | grep -E "JWT_SECRET|POSTGRES_PASSWORD|REDIS_PASSWORD"
# Should NOT show default/placeholder values!
# ------------------------------------------------------------------------------
