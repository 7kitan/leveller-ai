# ------------------------------------------------------------------------------
# 1. CORE INFRASTRUCTURE
# ------------------------------------------------------------------------------
# PostgreSQL (pgvector)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres  # SECURITY: Change this in production!
POSTGRES_DB=career_advisor
POSTGRES_HOST=advisor_db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=advisor_redis
REDIS_PORT=6379
REDIS_PASSWORD=  # SECURITY: Set a strong password in production!

# ------------------------------------------------------------------------------
# 2. AUTHENTICATION & SECURITY
# ------------------------------------------------------------------------------
# CRITICAL: Generate a strong JWT secret for production
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=super_secret_key_change_me
JWT_ALGORITHM=HS256

# SECURITY: Reduced from 1440 to 30 minutes for better security
# Shorter expiration reduces the window of opportunity if a token is stolen
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Default Admin (for scripts/setup_db.py)
# CRITICAL: Change these credentials immediately after first deployment!
DEFAULT_ADMIN_EMAIL=admin@lumix.ai
DEFAULT_ADMIN_PASSWORD=Admin@123  # SECURITY: Change this immediately!

# CORS Configuration
# SECURITY: In production, set this to your actual frontend domain(s)
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Environment (development, staging, production)
ENVIRONMENT=development

# ------------------------------------------------------------------------------
# 3. LLM CONFIGURATION
# ------------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-proj-...

# Optional Fallback
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 4. ANALYSIS ENGINE (GAP ANALYSIS v3)
# ------------------------------------------------------------------------------
# Matching Strategy
# true = dùng LangGraph Gap Agent | false = fallback về AdvancedGapEngine (vector)
USE_LLM_GAP_AGENT_V3=true
GAP_PII_MASKING=true

# Model riêng cho gap analysis (có thể dùng gpt-4o để tăng độ chính xác)
GAP_LLM_MODEL=gpt-4o-mini

# Matching Layers (Options: exact, semantic)
GAP_MATCHING_LAYERS=exact,semantic
GAP_VECTOR_SIM_THRESHOLD=0.35

# Advanced Scoring
GAP_VECTOR_PURE_SCORING=false

# ------------------------------------------------------------------------------
# 5. DATASET & PROCESSING
# ------------------------------------------------------------------------------
DATASET_DIR=/app/dataset
CV_UPLOAD_DIR=/app/data/cv_uploads
OCR_DPI=200
CV_PARSER_STRATEGY=chandra # Options: direct, chandra

# JD Search Behavior
JD_USE_VECTOR_SEARCH=true

# ------------------------------------------------------------------------------
# 6. EXTERNAL APIS (CORE CONTEXT)
# ------------------------------------------------------------------------------
# OCR Service (Chandra)
CHANDRA_API_URL=https://api.datalab.to/api/v1/ocr
CHANDRA_API_KEY=your_key_here

# Semantic Similarity Service (BertScore)
BERTSCORE_API_URL=https://api.yourserver.com/bertscore
BERTSCORE_API_KEY=your_key_here

# ------------------------------------------------------------------------------
# 7. EXTERNAL MEDIA & SEARCH
# ------------------------------------------------------------------------------
YOUTUBE_API_KEY=your_youtube_api_key_here
# GOOGLE_API_KEY is used as fallback for YouTube or for Google Search
GOOGLE_API_KEY=your_google_api_key_here
# Custom Search Engine ID (Optional)
GOOGLE_SEARCH_CX=your_cx_here

# ------------------------------------------------------------------------------
# 8. CACHING STRATEGY (REDIS)
# ------------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_KEY_PREFIX=advisor:
CACHE_DEFAULT_TTL=3600

# Layer Toggles
CACHE_AUTH_ENABLED=true
CACHE_RESULT_ENABLED=true
CACHE_LLM_ENABLED=true
CACHE_CV_RAW_TEXT_ENABLED=true
CACHE_CV_PARSED_JSON_ENABLED=true
GAP_REDIS_CACHE=true

# TTLS (Seconds)
GAP_CACHE_TTL=1800
JD_EXTRACT_CACHE_TTL=3600
CV_PARSED_CACHE_TTL=86400

# Cache Database Indexes (0-15)
CACHE_DB_AUTH=0
CACHE_DB_RESULT=2
CACHE_DB_LLM=3
